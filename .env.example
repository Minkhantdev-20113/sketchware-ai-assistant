# Supabase — create a project at https://supabase.com, then copy the URL and anon key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Cloudflare Worker — deploy cloudflare/ai-proxy first, then paste the Worker URL here
CLOUDFLARE_AI_PROXY_URL=https://your-worker.your-subdomain.workers.dev

# AI Provider API Keys (all optional — can also be stored as Cloudflare Worker secrets)
# Forwarded to the Worker as X-Provider-Api-Key when set.
# Get keys at:
#   OpenRouter: https://openrouter.ai/keys
#   Gemini:     https://aistudio.google.com/apikey
#   DeepSeek:   https://platform.deepseek.com/api_keys
#   Groq:       https://console.groq.com/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
GEMINI_API_KEY=your-gemini-api-key
DEEPSEEK_API_KEY=sk-your-deepseek-key
GROQ_API_KEY=your-groq-api-key
